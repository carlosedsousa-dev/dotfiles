{
    "layer": "top",
    "position": "top",
    "height": 46,
    "margin-top": 8,
    "margin-left": 10,
    "margin-right": 10,
    "spacing": 0,
    "reload_style_on_change": true,

    "modules-left": ["niri/workspaces", "niri/window"],
    "modules-center": ["clock"],
    "modules-right": ["cpu", "memory", "pulseaudio", "network", "battery", "tray"],

    "niri/workspaces": {
        "format": "{index}",
        "all-outputs": true
    },

    "niri/window": {
        "format": "{title}",
        "max-length": 30
    },

    "clock": {
        "format": "󰃰 {:%H:%M}"
    },

    "cpu": {
        "format": " {usage}%",
        "interval": 5 // Aumentei o intervalo para poupar o Celeron
    },

    "memory": {
        "format": " {percentage}%",
        "interval": 5
    },

    "network": {
        "format-wifi": " {ipaddr}",
        "format-ethernet": "󰈀 {ipaddr}",
        "format-disconnected": "󰖪 Off",
        "on-click": "kitty -e nmtui"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-icons": ["󰕿", "󰖀", "󰕾"],
        "on-click": "pavucontrol"
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": ["󰂎", "󰁺", "󰁹"]
    },

    "tray": {
        "spacing": 10
    }
}
