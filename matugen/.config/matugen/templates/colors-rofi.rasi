* {
    main-bg:            rgba({{colors.surface.default.red}}, {{colors.surface.default.green}}, {{colors.surface.default.blue}}, 0.9);
    main-fg:            {{colors.on_surface.default.hex}};
    main-br:            {{colors.primary.default.hex}};
    input-bg:           rgba({{colors.primary_container.default.red}}, {{colors.primary_container.default.green}}, {{colors.primary_container.default.blue}}, 0.2);
    select-bg:          rgba({{colors.primary.default.red}}, {{colors.primary.default.green}}, {{colors.primary.default.blue}}, 0.3);
    select-fg:          {{colors.primary.default.hex}};
}
